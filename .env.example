# CypCut Lazer Kesim Makinesi - Alarm & Duruş İzleme Sistemi
# .env dosyası proje kök dizinine kopyalanır ve değerler düzenlenir.

# --- Genel ---
# Makinenin adı, bildirimlerde görünecek
MACHINE_NAME=Lazer-1

# CypCut log klasörü
LOG_DIR=C:\Program Files (x86)\Friendess\Share\fsdc\log\LogFiles

# Log tail okuma aralığı (saniye). CPU kullanımını etkiler.
TAIL_POLL_INTERVAL=0.2

# --- Telegram ---
# BotFather'dan alınan token
TELEGRAM_BOT_TOKEN=PUT_YOUR_BOT_TOKEN_HERE

# Kanal/grup chat ID. Kanal/grup ID'si -100 ile başlar (ör: -1001234567890)
# Bot bu kanala/grup'a eklenmiş olmalı
TELEGRAM_CHAT_ID=PUT_YOUR_CHAT_ID_HERE

# Telegram polling aralığı (saniye)
TELEGRAM_POLL_INTERVAL=2.0

# DRY_RUN=true ise Telegram HTTP çağrıları atlanır, sadece loglanır
DRY_RUN=false

# --- Alarm ---
# Aynı alarm metni için yeniden bildirim göndermeme süresi (saniye)
ALARM_COOLDOWN_SECONDS=300

# --- Kamera ---
# Kullanılacak kamera indeksi. Boş bırakılırsa otomatik taranır.
# CAMERA_INDEX=0
CAMERA_INDEX=

# Kamera tarama aralığı (0-10 arası indexler denenir)
CAMERA_SCAN_MAX_INDEX=4

# Video süresi (saniye). Alarm ve duruşlarda çekilen video.
VIDEO_DURATION=5.0

# --- Veritabanı ---
DB_PATH=data\cypcut_monitor.db

# --- Uygulama logları ---
APP_LOG_PATH=logs\application.log
APP_LOG_LEVEL=INFO

# --- Retry Ayarları ---
# Telegram gönderilemeyen mesajlar için kontrol aralığı (saniye)
TELEGRAM_RETRY_CHECK_INTERVAL=5.0

# Log dizini oluşana kadar deneme aralığı (saniye)
LOG_WATCHER_RETRY_INTERVAL=10.0

# Log dosyası tarama aralığı (saniye) - fallback olarak kullanılır
LOG_FINDER_SCAN_INTERVAL=5.0
